{
  "expo": {
    "name": "DebtPath: Payoff Planner",
    "slug": "debtfree-payoff-planner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconApp.png",
    "scheme": "debtfree",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/iconApp.png",
      "resizeMode": "contain",
      "backgroundColor": "#EDE8D5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.debtfree.payoffplanner"
    },
    "android": {
      "package": "com.debtfree.payoffplanner",
      "adaptiveIcon": {
        "backgroundColor": "#EDE8D5",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://ac260501-19f4-4e19-9266-3a35fb42df7b-00-3aqy0whyan8o8.kirk.replit.dev:5000"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EDE8D5",
          "image": "./assets/images/iconApp.png",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#1C1610",
            "image": "./assets/images/iconApp.png"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
